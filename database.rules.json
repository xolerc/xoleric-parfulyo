{
  "rules": {
    "users": {
      ".read": true,
      ".write": true
    },
    "chat": {
      ".read": true,
      ".write": true,
      "rooms": {
        "$roomId": {
          ".validate": "newData.hasChildren(['id', 'name', 'creator'])"
        }
      },
      "$roomId": {
        "messages": {
          "$msgId": {
            ".validate": "newData.hasChildren(['fromId', 'fromName', 'time'])",
            "fromId": { ".validate": "newData.isString() && newData.val().length <= 50" },
            "fromName": { ".validate": "newData.isString() && newData.val().length <= 30" },
            "text": { ".validate": "newData.isString() && newData.val().length <= 2000" },
            "media": { ".validate": "newData.isString() && newData.val().length <= 9000000" },
            "time": { ".validate": "newData.isNumber()" },
            "reaction": { ".validate": "newData.isString() && newData.val().length <= 10" },
            "replyTo": { ".validate": "newData.isString() && newData.val().length <= 50" },
            "edited": { ".validate": "newData.isNumber()" }
          }
        },
        "info": {
          ".validate": "newData.hasChildren(['lastActivity'])"
        }
      }
    },
    "stats": {
      ".read": true,
      ".write": true
    }
  }
}
