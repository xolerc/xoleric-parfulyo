<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/widget_bg"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👨‍💻"
        android:textSize="28sp"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XOLERIC"
            android:textColor="#FFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Frontend arxitektori"
            android:textColor="#888"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
    android:gravity="center_vertical"
    android:id="@+id/widget_root">

            <TextView style="@style/SkillTag" android:text="React" />
            <TextView style="@style/SkillTag" android:text="Vue" />
            <TextView style="@style/SkillTag" android:text="Python" />
            <TextView style="@style/SkillTag" android:text="AI" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
